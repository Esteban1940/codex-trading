NODE_ENV=development
LOG_LEVEL=info

# Safety gates
LIVE_TRADING=false
KILL_SWITCH=false
LIQUIDATE_ON_RISK=true

# Binance (Spot)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_ENABLE_WITHDRAWALS=false

# Universe (hard requirement)
SYMBOLS=BTC/USDT,ETH/USDT
TIMEFRAMES=15m,1h

# Signal engine
SIGNAL_EMA_FAST=21
SIGNAL_EMA_SLOW=55
SIGNAL_RSI_PERIOD=14
SIGNAL_ROC_PERIOD=12
SIGNAL_ATR_PERIOD=14
SIGNAL_MAX_VOLATILITY_PCT=6
SIGNAL_COOLDOWN_MINUTES=30
SIGNAL_MIN_ENTRY_SCORE=0.25
SIGNAL_MIN_EDGE_MULTIPLIER=2
MIN_HOLD_MINUTES=45

# Risk
RISK_MAX_DAILY_LOSS_USDT=100
RISK_MAX_DAILY_LOSS_PCT=3
RISK_MAX_DRAWDOWN_PCT=10
RISK_MAX_TRADES_PER_DAY=20
RISK_ATR_CIRCUIT_BREAKER_PCT=8

# Stops
STOP_ATR_MULTIPLIER=2
TAKE_PROFIT_ATR_MULTIPLIER=3
TRAILING_STOP_ATR_MULTIPLIER=1.5

# Allocator
ALLOCATOR_MAX_EXPOSURE_TOTAL=0.8
ALLOCATOR_MAX_EXPOSURE_PER_SYMBOL=0.6
ALLOCATOR_REBALANCE_THRESHOLD=0.08
ALLOCATOR_MIN_SCORE_TO_INVEST=0.15

# Execution
DEFAULT_FEE_BPS=10
DEFAULT_SLIPPAGE_BPS=5
PAPER_SPREAD_BPS=6
EXEC_ENTRY_ORDER_TYPE=limit
EXEC_ENTRY_LIMIT_OFFSET_BPS=5
EXEC_ENTRY_LIMIT_TIMEOUT_MS=5000
EXEC_EXIT_ORDER_TYPE=market

# Worker
WORKER_INTERVAL_MS=60000
WORKER_MAX_CYCLES=0
WORKER_REAL_ADAPTER=false

# Compatibility / optional legacy keys
MAX_DAILY_LOSS_USD=100
MAX_DRAWDOWN_PCT=10
MAX_OPEN_POSITIONS=5
MAX_NOTIONAL_PER_SYMBOL_USD=500
MAX_NOTIONAL_PER_MARKET_USD=1500

# Optional IOL fields (unused in Binance-only flow)
IOL_BASE_URL=https://api.invertironline.com
IOL_SANDBOX_BASE_URL=https://api.invertironline.com
IOL_USERNAME=
IOL_PASSWORD=
IOL_ACCOUNT_ID=
IOL_USE_SANDBOX=true

SQLITE_PATH=./data/trading.db
POSTGRES_URL=postgresql://trader:trader@localhost:5432/trading
