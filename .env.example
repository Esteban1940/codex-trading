NODE_ENV=development
LOG_LEVEL=info

# Safety gates
LIVE_TRADING=false
# Keep true while testing with real adapter to prevent real orders.
READ_ONLY_MODE=true
KILL_SWITCH=false
LIQUIDATE_ON_RISK=true

# Binance (Spot)
# Default is mainnet + read-only for easiest smoke test.
# If BINANCE_TESTNET=true, credentials must come from Binance Spot Testnet.
# If BINANCE_TESTNET=false, credentials must come from Binance mainnet.
# In READ_ONLY_MODE=true, adapter can auto-fallback once between testnet/mainnet on auth mismatch (-2015).
BINANCE_API_KEY=
BINANCE_API_KEY_FILE=
BINANCE_API_SECRET=
BINANCE_API_SECRET_FILE=
BINANCE_TESTNET=false
# Optional override for spot testnet base URL when Binance demo endpoint differs from ccxt default.
# Example: https://demo-api.binance.com
BINANCE_TESTNET_BASE_URL=
BINANCE_ENABLE_WITHDRAWALS=false
BINANCE_USE_WS_QUOTES=true
BINANCE_WS_MAINNET_URL=wss://stream.binance.com:9443/stream
BINANCE_WS_TESTNET_URL=wss://stream.testnet.binance.vision/stream
BINANCE_WS_RECONNECT_MS=2000
BINANCE_WS_QUOTE_STALE_MS=8000
# Optional webhook for alerts (order executed, risk liquidation, worker crashes).
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_MS=3000
# Telegram alerts (recommended for production).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional forum topic/thread id in Telegram supergroups.
TELEGRAM_THREAD_ID=

# Universe (hard requirement)
SYMBOLS=BTC/USDT,ETH/USDT
TIMEFRAMES=15m,1h

# Signal engine
SIGNAL_EMA_FAST=21
SIGNAL_EMA_SLOW=55
SIGNAL_RSI_PERIOD=14
SIGNAL_ROC_PERIOD=12
SIGNAL_ATR_PERIOD=14
SIGNAL_MAX_VOLATILITY_PCT=6
SIGNAL_COOLDOWN_MINUTES=30
SIGNAL_TREND_FAST_WEIGHT=0.4
SIGNAL_TREND_SLOW_WEIGHT=0.6
SIGNAL_TREND_FAST_SCALE_PCT=0.25
SIGNAL_TREND_SLOW_SCALE_PCT=0.35
SIGNAL_REGIME_ENTRY_MIN=0.15
SIGNAL_REGIME_EXIT_MAX=-0.25
SIGNAL_EXIT_MOMENTUM_MAX=-0.30
SIGNAL_ACTION_ENTRY_SCORE_MIN=0.15
SIGNAL_SCORE_TREND_WEIGHT=0.7
SIGNAL_SCORE_MOMENTUM_WEIGHT=0.3
SIGNAL_MIN_ENTRY_SCORE=0.20
SIGNAL_MIN_EDGE_MULTIPLIER=1.2
# Optional cap for required edge (%). 0 disables cap.
SIGNAL_EDGE_PCT_CAP=0.25
SIGNAL_EVAL_ON_FAST_CANDLE_CLOSE_ONLY=true

# Starvation control (adaptive entry thresholds after prolonged no-entry streak)
STARVATION_FAST_CANDLES_NO_ENTRY=20
STARVATION_STEP_MIN_ENTRY_SCORE=0.01
STARVATION_STEP_ACTION_ENTRY_SCORE_MIN=0.01
STARVATION_STEP_REGIME_ENTRY_MIN=0.01
STARVATION_FLOOR_MIN_ENTRY_SCORE=0.08
STARVATION_FLOOR_ACTION_ENTRY_SCORE_MIN=0.06
STARVATION_FLOOR_REGIME_ENTRY_MIN=0.08

MIN_HOLD_MINUTES=30

# Risk
RISK_MAX_DAILY_LOSS_USDT=5
RISK_MAX_DAILY_LOSS_PCT=2
RISK_MAX_DRAWDOWN_PCT=6
RISK_MAX_TRADES_PER_DAY=2
RISK_ATR_CIRCUIT_BREAKER_PCT=8

# Live guardrails (validation hard limits applied when LIVE_TRADING=true)
LIVE_REQUIRE_CONSERVATIVE_LIMITS=true
LIVE_MAX_EXPOSURE_TOTAL_HARD=0.35
LIVE_MAX_EXPOSURE_PER_SYMBOL_HARD=0.2
LIVE_MAX_TRADES_PER_DAY_HARD=6
LIVE_MAX_DAILY_LOSS_PCT_HARD=2
LIVE_MAX_DAILY_LOSS_USDT_HARD=25
LIVE_MAX_NOTIONAL_PER_SYMBOL_USD_HARD=25
LIVE_MAX_NOTIONAL_PER_MARKET_USD_HARD=50

# Stops
STOP_ATR_MULTIPLIER=2
TAKE_PROFIT_ATR_MULTIPLIER=3
TRAILING_STOP_ATR_MULTIPLIER=1.5

# Allocator
# With ~94 USDT and MIN_NOTIONAL_USDT=10, per-symbol exposure must be >= 0.11 to allow orders.
ALLOCATOR_MAX_EXPOSURE_TOTAL=0.3
ALLOCATOR_MAX_EXPOSURE_PER_SYMBOL=0.15
ALLOCATOR_REBALANCE_THRESHOLD=0.08
ALLOCATOR_MIN_SCORE_TO_INVEST=0.10

# Execution
DEFAULT_FEE_BPS=10
DEFAULT_SLIPPAGE_BPS=5
PAPER_SPREAD_BPS=10
PAPER_INITIAL_USDT=10000
MIN_NOTIONAL_USDT=10
EXEC_ENTRY_ORDER_TYPE=limit
EXEC_ENTRY_LIMIT_OFFSET_BPS=5
EXEC_ENTRY_LIMIT_TIMEOUT_MS=5000
EXEC_EXIT_ORDER_TYPE=market

# Worker
WORKER_INTERVAL_MS=60000
WORKER_MAX_CYCLES=0
WORKER_REAL_ADAPTER=false
# Align worker sleep to next fast-candle close (+grace) to avoid no-new-candle churn.
WORKER_ALIGN_TO_FAST_CANDLE_CLOSE=true
WORKER_CANDLE_CLOSE_GRACE_MS=1500
# Quote freshness controls for order placement.
EXEC_QUOTE_MAX_AGE_MS=5000
EXEC_QUOTE_STALE_RETRY_COUNT=2
EXEC_QUOTE_STALE_RETRY_BACKOFF_MS=250
# Optional strict preflight for live min-notional feasibility.
LIVE_EQUITY_REFERENCE_USDT=0

# Compatibility / optional legacy keys
MAX_DAILY_LOSS_USD=100
MAX_DRAWDOWN_PCT=10
MAX_OPEN_POSITIONS=5
MAX_NOTIONAL_PER_SYMBOL_USD=20
MAX_NOTIONAL_PER_MARKET_USD=40

# Optional IOL fields (unused in Binance-only flow)
IOL_BASE_URL=https://api.invertironline.com
IOL_SANDBOX_BASE_URL=https://api.invertironline.com
IOL_USERNAME=
IOL_USERNAME_FILE=
IOL_PASSWORD=
IOL_PASSWORD_FILE=
IOL_ACCOUNT_ID=
IOL_ACCOUNT_ID_FILE=
IOL_USE_SANDBOX=true

SQLITE_PATH=./data/trading.db
POSTGRES_URL=postgresql://trader:trader@localhost:5432/trading
